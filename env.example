# Telegram bot token from @BotFather
BOT_TOKEN=000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Base URL of the FastAPI backend (no trailing slash)
API_URL=http://127.0.0.1:8000

# --- Backend (copy to backend/.env or set in docker-compose) ---

# SQLite by default; for Postgres use:
# DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/poetry

# OpenAI-compatible inference — matches openai.Client(base_url=..., api_key="None") in app.services.llm
# Host / uvicorn on machine: LLM_BASE_URL=http://127.0.0.1:3000/v1
# Docker Compose API container → llm service: set LLM_BASE_URL=http://llm:3000/v1 (compose default)
LLM_BASE_URL=http://127.0.0.1:3000/v1
LLM_API_KEY=None
LLM_MODEL=t-tech/T-lite-it-2.1-FP8

# Hugging Face token if the model is gated (optional)
# HF_TOKEN=

# Host port mapped to LLM container (container listens on 3000)
# LLM_HOST_PORT=3000

# Optional legacy / other uses
OPENAI_API_KEY=

# Local Whisper (faster-whisper) — voice messages; first run downloads weights
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# WHISPER_DOWNLOAD_ROOT=/path/to/cache
